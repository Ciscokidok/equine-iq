generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sex {
  mare
  stallion
  gelding
}

enum Discipline {
  sport_horse
  warmblood
  quarter_horse
  paint
  reining
  cutting
  barrel_racing
  flat_racing
  thoroughbred_racing
  hunter_jumper
  dressage
  eventing
  other
}

enum Plan {
  free
  breeder
  professional
  enterprise
}

enum RiskSeverity {
  low
  medium
  high
}

enum AuctionSaleType {
  weanling
  yearling
  two_year_old_in_training
  mixed_age
}

model User {
  id                       String    @id @default(uuid())
  email                    String    @unique
  passwordHash             String?
  farmName                 String?
  primaryDiscipline        Discipline?
  plan                     Plan      @default(free)
  subscriptionStatus       String?
  subscriptionEndDate      DateTime?
  stripeCustomerId         String?   @unique
  openaiApiKeyEncrypted    String?
  claimToken               String?   @unique
  claimTokenExpiry         DateTime?
  createdAt                DateTime  @default(now())

  mares        Horse[]         @relation("UserMares")
  pairings     MatingPairing[]
  foals        Foal[]
  auctionSales AuctionSale[]
}

model Horse {
  id                          String     @id @default(uuid())
  name                        String
  sex                         Sex
  breed                       String
  dateOfBirth                 DateTime?
  discipline                  Discipline
  color                       String?
  heightHands                 Float?
  conformationNotes           String?
  performanceRecords          Json       @default("[]")
  pedigree                    Json       @default("{}")
  studFee                     Int?
  studLocation                String?
  studBookingUrl              String?
  offspringCount              Int        @default(0)
  offspringPerformanceSummary String?
  registrationNumber          String?
  epdNotes                    String?
  externalProfileUrl          String?
  createdByUser               String?    // null = seed data
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  ownerMares       User?           @relation("UserMares", fields: [createdByUser], references: [id])
  marePairings     MatingPairing[] @relation("MarePairings")
  stallionPairings MatingPairing[] @relation("StallionPairings")
  foalMares        Foal[]          @relation("FoalMare")
  foalSires        Foal[]          @relation("FoalSire")
  heatCycles       HeatCycle[]

  @@index([sex])
  @@index([discipline])
  @@index([createdByUser])
}

model MatingPairing {
  id                 String   @id @default(uuid())
  userId             String
  mareId             String
  stallionId         String
  compatibilityScore Float
  scoreBreakdown     Json
  reasoning          String
  riskFlags          Json     @default("[]")
  topStrengths       Json     @default("[]")
  considerations     Json     @default("[]")
  goal               String
  notes              String?
  saved              Boolean  @default(false)
  createdAt          DateTime @default(now())

  user     User  @relation(fields: [userId], references: [id])
  mare     Horse @relation("MarePairings", fields: [mareId], references: [id])
  stallion Horse @relation("StallionPairings", fields: [stallionId], references: [id])
  foal     Foal?

  @@index([userId])
  @@index([mareId])
}

model Foal {
  id         String    @id @default(uuid())
  name       String?
  sex        Sex?
  foaledAt   DateTime?
  color      String?
  notes      String?
  mareId     String
  stallionId String?
  pairingId  String?   @unique
  userId     String
  createdAt  DateTime  @default(now())

  mare         Horse          @relation("FoalMare", fields: [mareId], references: [id])
  stallion     Horse?         @relation("FoalSire", fields: [stallionId], references: [id])
  pairing      MatingPairing? @relation(fields: [pairingId], references: [id])
  user         User           @relation(fields: [userId], references: [id])
  results      FoalResult[]
  auctionSales AuctionSale[]

  @@index([userId])
  @@index([mareId])
}

model FoalResult {
  id        String   @id @default(uuid())
  foalId    String
  event     String
  eventDate DateTime
  placement String?
  score     Float?
  earnings  Float?
  notes     String?
  createdAt DateTime @default(now())

  foal Foal @relation(fields: [foalId], references: [id], onDelete: Cascade)
}

model HeatCycle {
  id        String   @id @default(uuid())
  mareId    String
  startDate DateTime
  notes     String?
  createdAt DateTime @default(now())

  mare Horse @relation(fields: [mareId], references: [id], onDelete: Cascade)

  @@index([mareId])
}

model AuctionSale {
  id           String          @id @default(uuid())
  foalId       String
  userId       String
  salePrice    Float
  saleDate     DateTime
  saleType     AuctionSaleType
  auctionHouse String?
  hipNumber    String?
  buyer        String?
  notes        String?
  createdAt    DateTime        @default(now())

  foal Foal @relation(fields: [foalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([foalId])
  @@index([userId])
  @@index([userId, saleDate])
}
