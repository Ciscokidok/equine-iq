generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sex {
  mare
  stallion
  gelding
}

enum Discipline {
  sport_horse
  warmblood
  quarter_horse
  paint
  reining
  cutting
  barrel_racing
  flat_racing
  thoroughbred_racing
  hunter_jumper
  dressage
  eventing
  other
}

enum Plan {
  free
  breeder
  professional
  enterprise
}

enum RiskSeverity {
  low
  medium
  high
}

enum AuctionSaleType {
  weanling
  yearling
  two_year_old_in_training
  mixed_age
}

enum ListingStatus {
  pending_review
  approved
  rejected
  scheduled
  open
  closed
  seller_deciding
  counter_offering
  sold
  passed
}

enum ReserveBehavior {
  auto_pass
  seller_decision
  counter_offer
}

enum BidderApprovalStatus {
  pending
  approved
  suspended
}

enum AuctionSource {
  internal
  bidpath
  keeneland
  fasig_tipton
  obs
}

enum VettingDocType {
  coggins_test
  vet_certificate
  registration_papers
  bill_of_sale
  ownership_transfer
  radiographs
  endoscopy_video
}

enum VettingDocScanStatus {
  pending_scan
  clean
  rejected
}

model User {
  id                       String    @id @default(uuid())
  email                    String    @unique
  passwordHash             String?
  farmName                 String?
  primaryDiscipline        Discipline?
  plan                     Plan      @default(free)
  role                     String    @default("user")
  subscriptionStatus       String?
  subscriptionEndDate      DateTime?
  stripeCustomerId         String?   @unique
  openaiApiKeyEncrypted    String?
  claimToken               String?   @unique
  claimTokenExpiry         DateTime?
  createdAt                DateTime  @default(now())

  mares               Horse[]             @relation("UserMares")
  pairings            MatingPairing[]
  foals               Foal[]
  breedings           Breeding[]
  auctionSales        AuctionSale[]
  sellerListings      AuctionListing[]    @relation("SellerListings")
  bids                Bid[]
  bidderApproval      BidderApproval?
  auctionWatchers     AuctionWatcher[]
  highBidAuctions     Auction[]           @relation("AuctionHighBidder")
  importBatches       ImportBatch[]
  userProviderConfigs UserProviderConfig[]
  studBookings        StudBooking[]
}

model Horse {
  id                          String     @id @default(uuid())
  name                        String
  sex                         Sex
  breed                       String
  dateOfBirth                 DateTime?
  discipline                  Discipline
  color                       String?
  heightHands                 Float?
  conformationNotes           String?
  performanceRecords          Json       @default("[]")
  pedigree                    Json       @default("{}")
  studFee                     Int?
  studLocation                String?
  studBookingUrl              String?
  offspringCount              Int        @default(0)
  offspringPerformanceSummary String?
  registrationNumber          String?
  epdNotes                    String?
  externalProfileUrl          String?
  createdByUser               String?    // null = seed data
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  ownerMares           User?           @relation("UserMares", fields: [createdByUser], references: [id])
  marePairings         MatingPairing[] @relation("MarePairings")
  stallionPairings     MatingPairing[] @relation("StallionPairings")
  foalMares            Foal[]          @relation("FoalMare")
  foalSires            Foal[]          @relation("FoalSire")
  heatCycles           HeatCycle[]
  auctionListings      AuctionListing[]
  saleRecords          SaleRecord[]
  racingEarnings       RacingEarnings?
  productionCosts      ProductionCost[]
  breedingsMare        Breeding[]      @relation("BreedingMare")
  breedingsStallion    Breeding[]      @relation("BreedingStallion")
  studBookingsMare     StudBooking[]   @relation("StudBookingMare")
  studBookingsStallion StudBooking[]   @relation("StudBookingStallion")

  @@index([sex])
  @@index([discipline])
  @@index([createdByUser])
}

model MatingPairing {
  id                 String   @id @default(uuid())
  userId             String
  mareId             String
  stallionId         String
  compatibilityScore Float
  scoreBreakdown     Json
  reasoning          String
  riskFlags          Json     @default("[]")
  topStrengths       Json     @default("[]")
  considerations     Json     @default("[]")
  goal               String
  notes              String?
  saved              Boolean  @default(false)
  createdAt          DateTime @default(now())

  user     User  @relation(fields: [userId], references: [id])
  mare     Horse @relation("MarePairings", fields: [mareId], references: [id])
  stallion Horse @relation("StallionPairings", fields: [stallionId], references: [id])
  foal     Foal?

  @@index([userId])
  @@index([mareId])
}

model Foal {
  id         String    @id @default(uuid())
  name       String?
  sex        Sex?
  foaledAt   DateTime?
  color      String?
  notes      String?
  mareId     String
  stallionId String?
  pairingId       String?   @unique
  breedingId      String?   @unique
  promotedHorseId String?   @unique
  userId          String
  createdAt       DateTime  @default(now())

  mare         Horse          @relation("FoalMare", fields: [mareId], references: [id])
  stallion     Horse?         @relation("FoalSire", fields: [stallionId], references: [id])
  pairing      MatingPairing? @relation(fields: [pairingId], references: [id])
  breeding     Breeding?      @relation(fields: [breedingId], references: [id])
  user         User           @relation(fields: [userId], references: [id])
  results      FoalResult[]
  auctionSales AuctionSale[]

  @@index([userId])
  @@index([mareId])
}

model FoalResult {
  id        String   @id @default(uuid())
  foalId    String
  event     String
  eventDate DateTime
  placement String?
  score     Float?
  earnings  Float?
  notes     String?
  createdAt DateTime @default(now())

  foal Foal @relation(fields: [foalId], references: [id], onDelete: Cascade)
}

model HeatCycle {
  id        String   @id @default(uuid())
  mareId    String
  startDate DateTime
  notes     String?
  createdAt DateTime @default(now())

  mare Horse @relation(fields: [mareId], references: [id], onDelete: Cascade)

  @@index([mareId])
}

model AuctionSale {
  id           String          @id @default(uuid())
  foalId       String
  userId       String
  salePrice    Float
  saleDate     DateTime
  saleType     AuctionSaleType
  auctionHouse String?
  hipNumber    String?
  buyer        String?
  notes        String?
  createdAt    DateTime        @default(now())

  foal Foal @relation(fields: [foalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([foalId])
  @@index([userId])
  @@index([userId, saleDate])
}

model AuctionListing {
  id                String        @id @default(uuid())
  horseId           String
  sellerId          String
  status            ListingStatus @default(pending_review)
  reservePrice      Int?
  reserveBehavior   ReserveBehavior @default(auto_pass)
  buyersPremiumPct  Float         @default(10)
  notes             String?
  vetApprovedAt     DateTime?
  vetRejectedAt     DateTime?
  vetRejectedReason String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  horse            Horse            @relation(fields: [horseId], references: [id])
  seller           User             @relation("SellerListings", fields: [sellerId], references: [id])
  vettingDocuments VettingDocument[]
  auction          Auction?

  @@index([sellerId])
  @@index([status])
}

model VettingDocument {
  id         String               @id @default(uuid())
  listingId  String
  docType    VettingDocType
  fileName   String
  s3Key      String
  mimeType   String
  scanStatus VettingDocScanStatus @default(pending_scan)
  uploadedAt DateTime             @default(now())

  listing AuctionListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Auction {
  id                    String        @id @default(uuid())
  listingId             String        @unique
  status                ListingStatus @default(scheduled)
  startingBid           Int
  bidIncrement          Int           @default(100)
  currentBid            Int           @default(0)
  highBidderId          String?
  highGuestBidderId     String?
  startAt               DateTime
  endsAt                DateTime
  closedAt              DateTime?
  sellerDecisionDeadline DateTime?
  paymentConfirmedAt    DateTime?
  auctionSource         AuctionSource @default(internal)
  externalLotId         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  listing     AuctionListing   @relation(fields: [listingId], references: [id])
  highBidder  User?            @relation("AuctionHighBidder", fields: [highBidderId], references: [id])
  highGuest   GuestBidder?     @relation("AuctionHighGuest", fields: [highGuestBidderId], references: [id])
  bids        Bid[]
  watchers    AuctionWatcher[]

  @@index([status])
  @@index([auctionSource, externalLotId])
}

model Bid {
  id              String   @id @default(uuid())
  auctionId       String
  userId          String?
  guestBidderId   String?
  amount          Int
  isAutoBid       Boolean  @default(false)
  autoMaxAmount   Int?
  placedAt        DateTime @default(now())

  auction     Auction      @relation(fields: [auctionId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  guestBidder GuestBidder? @relation(fields: [guestBidderId], references: [id])

  @@index([auctionId])
  @@index([userId])
}

model BidderApproval {
  id                 String               @id @default(uuid())
  userId             String?              @unique
  guestBidderId      String?              @unique
  status             BidderApprovalStatus @default(pending)
  depositAmount      Int?
  depositReference   String?
  depositConfirmedAt DateTime?
  approvedAt         DateTime?
  suspendedAt        DateTime?
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user        User?        @relation(fields: [userId], references: [id])
  guestBidder GuestBidder? @relation(fields: [guestBidderId], references: [id])
}

model GuestBidder {
  id            String   @id @default(uuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  verifyToken   String?  @unique
  verifyExpiry  DateTime?
  createdAt     DateTime @default(now())

  bids           Bid[]
  bidderApproval BidderApproval?
  highBidAuctions Auction[]      @relation("AuctionHighGuest")
}

model AuctionWatcher {
  id        String   @id @default(uuid())
  auctionId String
  userId    String?
  email     String?
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([auctionId, userId])
  @@unique([auctionId, email])
  @@index([auctionId])
}

model AdapterConfig {
  source    String   @id
  active    Boolean  @default(false)
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt
}

enum DataProvider {
  sporthorse_data
  equibase
  tjcis
}

enum ImportSource {
  csv
  api
}

enum ImportStatus {
  processing
  completed
  failed
}

enum BreedingStatus {
  bred
  confirmed_in_foal
  foaled
  slipped
  barren
}

enum StudBookingStatus {
  pending_payment
  confirmed
  breeding_complete
  cancelled
}

model SaleRecord {
  id               String    @id @default(cuid())
  horseId          String
  importBatchId    String?
  saleSource       String
  saleSessionName  String?
  saleDate         DateTime
  hipNumber        String?
  hammerPriceCents Int
  buyerName        String?
  consignorName    String?
  providerRef      String?
  createdAt        DateTime  @default(now())

  horse       Horse        @relation(fields: [horseId], references: [id])
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id])

  @@unique([horseId, hipNumber, saleDate])
  @@index([horseId])
  @@index([importBatchId])
}

model Breeding {
  id            String         @id @default(cuid())
  userId        String
  mareId        String
  stallionId    String
  bredDate      DateTime
  status        BreedingStatus @default(bred)
  studFeeCents  Int?
  confirmedAt   DateTime?
  expectedFoalDate DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user     User  @relation(fields: [userId], references: [id])
  mare     Horse @relation("BreedingMare", fields: [mareId], references: [id])
  stallion Horse @relation("BreedingStallion", fields: [stallionId], references: [id])
  foal     Foal?

  @@index([userId])
  @@index([mareId])
}

model RacingEarnings {
  id                 String   @id @default(cuid())
  horseId            String   @unique
  horse              Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  totalEarningsCents BigInt   @default(0)
  starts             Int?
  wins               Int?
  places             Int?
  shows              Int?
  bestRaceClass      String?
  notes              String?
  sourceUrl          String?
  updatedByUserId    String?
  updatedAt          DateTime @updatedAt
}

model ProductionCost {
  id          String   @id @default(cuid())
  horseId     String
  horse       Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  userId      String
  category    String
  amountCents Int
  year        Int
  notes       String?
  createdAt   DateTime @default(now())

  @@index([horseId])
  @@index([userId])
}

model ImportBatch {
  id               String        @id @default(cuid())
  importedByUserId String
  source           ImportSource
  provider         DataProvider?
  sourceFileName   String?
  totalRows        Int           @default(0)
  createdCount     Int           @default(0)
  matchedCount     Int           @default(0)
  errorCount       Int           @default(0)
  status           ImportStatus  @default(processing)
  errorLog         Json          @default("[]")
  createdAt        DateTime      @default(now())

  importedByUser User         @relation(fields: [importedByUserId], references: [id])
  saleRecords    SaleRecord[]

  @@index([importedByUserId])
}

model UserProviderConfig {
  id                  String       @id @default(cuid())
  userId              String
  provider            DataProvider
  encryptedCredential String
  testStatus          String?
  testedAt            DateTime?
  createdAt           DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
  @@index([userId])
}

model PlatformProviderConfig {
  provider            DataProvider @id
  encryptedCredential String
  active              Boolean      @default(false)
  testedAt            DateTime?
  createdAt           DateTime     @default(now())
}

model StudBooking {
  id              String            @id @default(uuid())
  userId          String
  mareId          String
  stallionId      String
  feePaidCents    Int
  stripeSessionId String?           @unique
  status          StudBookingStatus @default(pending_payment)
  scheduledDate   DateTime?
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime          @default(now())

  user     User  @relation(fields: [userId], references: [id])
  mare     Horse @relation("StudBookingMare", fields: [mareId], references: [id])
  stallion Horse @relation("StudBookingStallion", fields: [stallionId], references: [id])

  @@index([userId])
}
